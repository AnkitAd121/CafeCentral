{
  "theme": "Light",
  "archetype": "Organic & Earthy",
  "colors": {
    "light": {
      "background": "hsl(36, 33%, 97%)",
      "foreground": "hsl(25, 15%, 15%)",
      "primary": "hsl(25, 60%, 35%)",
      "card": "hsl(36, 25%, 95%)",
      "muted": "hsl(36, 20%, 92%)",
      "accent": "hsl(36, 40%, 85%)",
      "border": "hsl(36, 20%, 85%)",
      "custom_tokens": {
        "--cream": "hsl(36, 33%, 97%)",
        "--espresso": "hsl(25, 15%, 15%)",
        "--latte": "hsl(36, 25%, 95%)",
        "--amber": "hsl(38, 70%, 55%)",
        "--warmborder": "hsl(36, 20%, 85%)"
      }
    },
    "dark": {
      "background": "hsl(25, 20%, 8%)",
      "foreground": "hsl(36, 33%, 97%)",
      "primary": "hsl(38, 70%, 55%)",
      "card": "hsl(25, 15%, 12%)",
      "muted": "hsl(25, 15%, 15%)",
      "accent": "hsl(25, 30%, 20%)",
      "border": "hsl(25, 20%, 18%)"
    }
  },
  "typography": {
    "headings": {
      "family": "Fraunces, serif",
      "weights": ["400", "600", "700"],
      "styles": ["normal", "italic"]
    },
    "body": {
      "family": "Inter, sans-serif",
      "weights": ["400", "500"]
    },
    "usage": {
      "h1": "text-5xl md:text-6xl font-serif tracking-tight",
      "h2": "text-3xl md:text-4xl font-serif",
      "taglines": "text-xl md:text-2xl font-serif italic text-primary",
      "body": "text-base font-sans text-foreground/80"
    }
  },
  "border_radius": {
    "cards": "rounded-2xl",
    "buttons": "rounded-full",
    "inputs": "rounded-xl",
    "tags": "rounded-full"
  },
  "animations": {
    "page_load": {
      "initial": { "opacity": 0, "transform": "translateY(20px)" },
      "animate": { "opacity": 1, "transform": "translateY(0)" },
      "transition": "700ms cubic-bezier(0.16, 1, 0.3, 1)",
      "stagger": "100-500ms"
    },
    "card_hover": {
      "transform": "translateY(-4px)",
      "box_shadow": "0 10px 40px -10px rgba(0,0,0,0.1)",
      "border": "border-primary",
      "image_zoom": "scale(1.05) transition-transform duration-500"
    }
  },
  "interactions": {
    "scrollbar": "thin 6px, warm muted track, latte thumb, primary on hover",
    "focus_ring": "focus:ring-2 focus:ring-primary/30 focus:outline-none"
  },
  "layout": {
    "grid": "bento/editorial style, wide margins, generous padding (p-8 to p-12)",
    "cards": "responsive cafe card grid (3/2/1 cols), card with hero image 16:10",
    "floating_tooltip": "fade+scale animation on hover for cafe info"
  },
